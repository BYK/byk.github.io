<button id="theme-toggle" class="text-xl leading-none" title="Theme: system"
  ><span data-icon="light" class="hidden">&#x2600;&#xFE0F;</span
  ><span data-icon="dark" class="hidden">&#x1F319;</span
  ><span data-icon="system" class="hidden">&#x1F317;</span
></button>

<script>
  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const icons = {
      light:  btn.querySelector('[data-icon="light"]'),
      dark:   btn.querySelector('[data-icon="dark"]'),
      system: btn.querySelector('[data-icon="system"]'),
    };

    const cycle = { system: 'light', light: 'dark', dark: 'system' };

    function getTheme() {
      const t = localStorage.theme;
      return (t === 'light' || t === 'dark') ? t : 'system';
    }

    function updateIcon() {
      const current = getTheme();
      for (const key in icons) {
        icons[key].classList.toggle('hidden', key !== current);
      }
      btn.title = 'Theme: ' + current;
    }

    btn.addEventListener('click', function () {
      const newTheme = cycle[getTheme()];
      if (newTheme === 'system') {
        delete localStorage.theme;
      } else {
        localStorage.theme = newTheme;
      }
      window.__applyTheme();
      updateIcon();
    });

    updateIcon();
  }

  setupThemeToggle();
  document.addEventListener('astro:after-swap', setupThemeToggle);
</script>
